  {
    "id": "json_parse_casa_data",
    "type": "json",
    "z": "flow_m2_iot_automacao",
    "name": "Converter JSON para objeto",
    "property": "payload",
    "action": "obj",
    "pretty": false,
    "x": 390,
    "y": 120,
    "wires": [["fn_distribuir_telemetria"]]
  },
  {
    "id": "fn_distribuir_telemetria",
    "type": "function",
    "z": "flow_m2_iot_automacao",
    "name": "Validar e distribuir telemetria",
    "func": "const p = msg.payload;\n\nif (typeof p !== \"object\" || p === null || Array.isArray(p)) {\n    node.warn(\"Payload casa/data inválido: esperado objeto JSON.\");\n    return [null, null, null, null, null, null, null, null, null, null];\n}\n\nfunction toNumber(value, fallback) {\n    const n = Number(value);\n    return Number.isFinite(n) ? n : fallback;\n}\n\nfunction toBoolean(value) {\n    return value === true || value === 1 || value === \"1\" || value === \"true\" || value === \"on\";\n}\n\nfunction formatUptime(ms) {\n    const totalSeconds = Math.max(0, Math.floor(toNumber(ms, 0) / 1000));\n    const days = Math.floor(totalSeconds / 86400);\n    const hours = Math.floor((totalSeconds % 86400) / 3600);\n    const minutes = Math.floor((totalSeconds % 3600) / 60);\n    const seconds = totalSeconds % 60;\n\n    if (days > 0) {\n        return `${days}d ${hours}h ${minutes}m ${seconds}s`;\n    }\n    if (hours > 0) {\n        return `${hours}h ${minutes}m ${seconds}s`;\n    }\n    if (minutes > 0) {\n        return `${minutes}m ${seconds}s`;\n    }\n    return `${seconds}s`;\n}\n\nconst normalized = {\n    temp: toNumber(p.temp, 0),\n    humidity: toNumber(p.humidity, 0),\n    distance_cm: toNumber(p.distance_cm, 0),\n    light: toNumber(p.light, 0),\n    motion: toBoolean(p.motion),\n    led: toNumber(p.led, 0),\n    relay: toNumber(p.relay, 0),\n    buzzer: toNumber(p.buzzer, 0),\n    servo_angle: toNumber(p.servo_angle, 0),\n    auto_mode: toBoolean(p.auto_mode),\n    wifi_ip: p.wifi_ip ? String(p.wifi_ip) : \"-\",\n    mqtt: p.mqtt ? String(p.mqtt) : \"desconhecido\",\n    uptime_ms: toNumber(p.uptime_ms, 0),\n    last_error: p.last_error ? String(p.last_error) : \"\"\n};\n\nmsg.payload = Object.assign({}, p, normalized);\n\nreturn [\n    { payload: normalized.temp, topic: \"Temperatura\" },\n    { payload: normalized.humidity, topic: \"Umidade\" },\n    { payload: normalized.light, topic: \"Luminosidade\" },\n    { payload: normalized.motion, topic: \"Movimento\" },\n    { payload: normalized.distance_cm.toFixed(1), topic: \"Distância\" },\n    { payload: normalized.wifi_ip, topic: \"IP WiFi\" },\n    { payload: normalized.mqtt, topic: \"MQTT\" },\n    { payload: formatUptime(normalized.uptime_ms), topic: \"Uptime\" },\n    { payload: normalized.last_error || \"sem erro\", topic: \"Último erro\" },\n    { payload: msg.payload, topic: \"Telemetria normalizada\" }\n];",
    "outputs": 10,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 660,
    "y": 120,
    "wires": [
      ["ui_gauge_temp"],
      ["ui_gauge_humidity"],
      ["ui_chart_light"],
      ["ui_template_motion"],
      ["ui_text_distance"],
      ["ui_text_wifi_ip"],
      ["ui_text_mqtt_status"],
      ["ui_text_uptime"],
      ["ui_text_last_error"],
      ["fn_filtrar_alertas", "debug_telemetria_normalizada"]
    ]
  },
