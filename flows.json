  {
    "id": "fn_filtrar_alertas",
    "type": "function",
    "z": "flow_m2_iot_automacao",
    "name": "Filtrar alertas: movimento OU distância < 10",
    "func": "const p = msg.payload || {};\n\nfunction toNumber(value) {\n    const n = Number(value);\n    return Number.isFinite(n) ? n : NaN;\n}\n\nfunction toBoolean(value) {\n    return value === true || value === 1 || value === \"1\" || value === \"true\" || value === \"on\";\n}\n\nfunction present(value) {\n    return value === undefined || value === null ? \"\" : value;\n}\n\nconst motion = toBoolean(p.motion);\nconst distance = toNumber(p.distance_cm);\nconst distanceAlert = Number.isFinite(distance) && distance < 10;\n\nif (!motion && !distanceAlert) {\n    return [null, null];\n}\n\nconst timestamp = new Date().toISOString();\nconst events = [];\n\nif (motion) {\n    events.push(\"MOVIMENTO\");\n}\n\nif (distanceAlert) {\n    events.push(\"DISTANCIA_CRITICA\");\n}\n\nconst event = events.join(\" + \");\nconst value = [\n    motion ? \"motion=true\" : \"\",\n    distanceAlert ? `distance_cm=${distance.toFixed(1)}` : \"\"\n].filter(Boolean).join(\"; \");\n\nconst row = [\n    timestamp,\n    event,\n    value,\n    present(p.temp),\n    present(p.humidity),\n    Number.isFinite(distance) ? Number(distance.toFixed(1)) : \"\",\n    present(p.light),\n    motion,\n    present(p.wifi_ip),\n    present(p.uptime_ms),\n    present(p.last_error)\n];\n\nconst sheetMsg = {\n    payload: row,\n    topic: \"Alerta IoT\",\n    alert: {\n        timestamp,\n        event,\n        value\n    }\n};\n\nconst emailMsg = {\n    topic: `[M2 IoT] ${event}`,\n    payload:\n`Alerta detectado no Projeto M2 - Automação Residencial IoT\n\nTimestamp: ${timestamp}\nEvento: ${event}\nValor: ${value}\n\nTelemetria:\n- Temperatura: ${present(p.temp)} °C\n- Umidade: ${present(p.humidity)} %\n- Distância: ${Number.isFinite(distance) ? distance.toFixed(1) : \"\"} cm\n- Luminosidade: ${present(p.light)}\n- Movimento: ${motion}\n- LED: ${present(p.led)}\n- Relé: ${present(p.relay)}\n- Buzzer: ${present(p.buzzer)}\n- Servo: ${present(p.servo_angle)}\n- Modo automático: ${present(p.auto_mode)}\n- IP WiFi: ${present(p.wifi_ip)}\n- MQTT: ${present(p.mqtt)}\n- Uptime: ${present(p.uptime_ms)} ms\n- Último erro: ${present(p.last_error)}\n\nOrigem: Node-RED / Projeto M2`\n};\n\nreturn [sheetMsg, emailMsg];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 390,
    "y": 480,
    "wires": [["gsheet_append_alerta"], ["email_alerta_m2"]]
